# Docker Compose variables for SaveWise Protocol.
# Copy this file to .env and fill secrets locally.
# Do not commit .env to GitHub.

JWT_SECRET=change_me

# Private key for backend service account.
BACKEND_PRIVATE_KEY=

# Comma-separated private keys for custodial user wallets.
CUSTODIAL_PRIVATE_KEYS=

# Groq AI module.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant