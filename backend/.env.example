PORT=4000
NODE_ENV=development

DATABASE_URL="file:./dev.db"

JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

RPC_URL=http://127.0.0.1:8545
CONTRACTS_DIR=../shared/contracts

# Backend service private key.
# Fill this value only in your local backend/.env file.
BACKEND_PRIVATE_KEY=

# Comma-separated private keys used for user custodial wallets.
# Fill this value only in your local backend/.env file.
CUSTODIAL_PRIVATE_KEYS=

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant